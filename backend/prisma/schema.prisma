// KODI Rental Management Platform — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UnitStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum PaymentChannel {
  MPESA
  CASH
  BANK
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  SECURITY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum DepositStatus {
  HELD
  PARTIALLY_REFUNDED
  FULLY_REFUNDED
  FORFEITED
}

enum BroadcastChannel {
  SMS
  WHATSAPP
  BOTH
}

enum LandlordPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  LANDLORD
  CARETAKER
  TENANT
  ADMIN
}

// ─── Models ─────────────────────────────────────────────────────────────────

model Landlord {
  id                String             @id @default(uuid())
  name              String
  phone             String             @unique
  email             String             @unique
  passwordHash      String
  plan              LandlordPlan       @default(FREE)
  language          String             @default("en")
  currencyPref      String             @default("KES")
  monthlyAirtimeCap Int                @default(5000)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  properties        Property[]
  caretakers        Caretaker[]
  broadcasts        BroadcastMessage[]
  iTaxReports       iTaxReport[]
  advances          RentAdvance[]
  refreshTokens     RefreshToken[]

  @@map("landlords")
}

model Caretaker {
  id          String    @id @default(uuid())
  landlordId  String
  name        String
  phone       String    @unique
  passwordHash String
  permissions String[]  @default([])
  language    String    @default("en")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  landlord    Landlord  @relation(fields: [landlordId], references: [id])
  refreshTokens RefreshToken[]

  @@map("caretakers")
}

model Property {
  id         String    @id @default(uuid())
  landlordId String
  name       String
  address    String
  county     String
  type       String    // e.g. "APARTMENT", "BEDSITTER", "MAISONETTE"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  landlord   Landlord  @relation(fields: [landlordId], references: [id])
  units      Unit[]
  broadcasts BroadcastMessage[]

  @@map("properties")
}

model Unit {
  id           String        @id @default(uuid())
  propertyId   String
  unitNumber   String
  rentAmount   Decimal       @db.Decimal(12, 2)
  status       UnitStatus    @default(VACANT)
  floor        Int?
  bedrooms     Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id])
  tenants      Tenant[]
  payments     Payment[]
  tickets      MaintenanceTicket[]

  @@unique([propertyId, unitNumber])
  @@map("units")
}

model Tenant {
  id              String         @id @default(uuid())
  unitId          String?
  name            String
  phone           String         @unique
  email           String?
  idNumber        String         // encrypted at app level
  leaseStart      DateTime
  leaseEnd        DateTime?
  depositAmount   Decimal        @db.Decimal(12, 2)
  depositStatus   DepositStatus  @default(HELD)
  passwordHash    String
  language        String         @default("en")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  unit            Unit?          @relation(fields: [unitId], references: [id])
  payments        Payment[]
  tickets         MaintenanceTicket[]
  airtimeRewards  AirtimeReward[]
  trustScore      TrustScore?
  creditPassport  CreditPassport?
  leases          Lease[]
  refreshTokens   RefreshToken[]

  @@map("tenants")
}

model Payment {
  id                   String         @id @default(uuid())
  tenantId             String
  unitId               String
  amount               Decimal        @db.Decimal(12, 2)
  mpesaTransactionId   String?        @unique
  channel              PaymentChannel
  paymentDate          DateTime
  periodMonth          Int            // 1-12
  periodYear           Int
  isPartial            Boolean        @default(false)
  daysLate             Int            @default(0)
  lateFee              Decimal        @default(0) @db.Decimal(12, 2)
  notes                String?
  createdAt            DateTime       @default(now())

  tenant               Tenant         @relation(fields: [tenantId], references: [id])
  unit                 Unit           @relation(fields: [unitId], references: [id])

  @@map("payments")
}

model MaintenanceTicket {
  id               String              @id @default(uuid())
  unitId           String
  tenantId         String
  category         MaintenanceCategory
  description      String
  voiceRecordingUrl String?
  status           TicketStatus        @default(OPEN)
  priority         String              @default("NORMAL") // NORMAL | URGENT
  assignedTo       String?             // Caretaker name / fundi
  rating           Int?                // 1-5 stars from tenant
  ratingComment    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  closedAt         DateTime?

  unit             Unit                @relation(fields: [unitId], references: [id])
  tenant           Tenant              @relation(fields: [tenantId], references: [id])

  @@map("maintenance_tickets")
}

model AirtimeReward {
  id        String   @id @default(uuid())
  tenantId  String
  amount    Decimal  @db.Decimal(8, 2)
  reason    String
  phone     String
  status    String   @default("PENDING") // PENDING | SENT | FAILED
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("airtime_rewards")
}

model TrustScore {
  id          String   @id @default(uuid())
  tenantId    String   @unique
  score       Int      @default(500)
  lastUpdated DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@map("trust_scores")
}

model CreditPassport {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  totalMonths      Int      @default(0)
  onTimeMonths     Int      @default(0)
  lateMonths       Int      @default(0)
  partialMonths    Int      @default(0)
  missedMonths     Int      @default(0)
  averageDaysLate  Decimal  @default(0) @db.Decimal(5, 2)
  lastUpdated      DateTime @default(now())

  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@map("credit_passports")
}

model BroadcastMessage {
  id             String           @id @default(uuid())
  landlordId     String
  propertyId     String?
  message        String
  channel        BroadcastChannel
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int              @default(0)
  status         String           @default("PENDING") // PENDING | SENT | FAILED
  createdAt      DateTime         @default(now())

  landlord       Landlord         @relation(fields: [landlordId], references: [id])
  property       Property?        @relation(fields: [propertyId], references: [id])

  @@map("broadcast_messages")
}

model iTaxReport {
  id           String   @id @default(uuid())
  landlordId   String
  year         Int
  quarter      String   // Q1 | Q2 | Q3 | Q4 | ANNUAL
  totalIncome  Decimal  @db.Decimal(14, 2)
  generatedAt  DateTime @default(now())
  csvUrl       String?
  pdfUrl       String?

  landlord     Landlord @relation(fields: [landlordId], references: [id])

  @@map("itax_reports")
}

model RentAdvance {
  id              String   @id @default(uuid())
  landlordId      String
  requestedAmount Decimal  @db.Decimal(14, 2)
  feeAmount       Decimal  @db.Decimal(14, 2)
  netAmount       Decimal  @db.Decimal(14, 2)
  status          String   @default("PENDING") // PENDING | APPROVED | REPAID
  requestedAt     DateTime @default(now())
  approvedAt      DateTime?
  repaidAt        DateTime?
  notes           String?

  landlord        Landlord @relation(fields: [landlordId], references: [id])

  @@map("rent_advances")
}

model Lease {
  id          String   @id @default(uuid())
  tenantId    String
  unitId      String
  landlordId  String
  customTerms String?
  pdfUrl      String?
  language    String   @default("en")
  signedAt    DateTime?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@map("leases")
}

model UssdSession {
  id          String   @id @default(uuid())
  sessionId   String   @unique
  phoneNumber String
  step        String
  role        String?
  tenantId    String?
  landlordId  String?
  caretakerId String?
  language    String   @default("en")
  data        Json?    // arbitrary session payload
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ussd_sessions")
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  landlordId  String?
  caretakerId String?
  tenantId    String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  landlord    Landlord?  @relation(fields: [landlordId], references: [id])
  caretaker   Caretaker? @relation(fields: [caretakerId], references: [id])
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])

  @@map("refresh_tokens")
}
