# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@kodisha.ke
SUPER_ADMIN_PHONE=+254700000000
SUPER_ADMIN_PASSWORD=replace_with_secure_initial_password
# Set to true only if you want public landlord self-registration in production.
ALLOW_PUBLIC_REGISTRATION=false

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kodi_user:kodi_pass@localhost:5432/kodi_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Africa's Talking ─────────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox                    # Use 'sandbox' for testing
AT_USSD_CODE=*384*100#
AT_SENDER_ID=KODI
AT_VOICE_NUMBER=+254711082XXX
# Whitelisted AT IPs (comma-separated), get from AT docs
AT_WHITELISTED_IPS=196.201.214.200,196.201.214.201,196.201.214.202,196.201.214.203,196.201.214.204,196.201.214.207,196.201.214.208,196.201.214.209,196.201.214.210,196.201.214.211,196.201.214.212,196.201.214.213

# ─── Safaricom Daraja (M-Pesa) ────────────────────────────────────────────────
MPESA_ENV=sandbox                      # sandbox | production
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                 # Your business shortcode
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback
MPESA_B2C_INITIATOR=apitest254
MPESA_B2C_SECURITY_CREDENTIAL=your_b2c_credential
MPESA_B2C_QUEUE_TIMEOUT_URL=https://yourdomain.com/mpesa/b2c/timeout
MPESA_B2C_RESULT_URL=https://yourdomain.com/mpesa/b2c/result

# ─── Twilio (WhatsApp) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Open Exchange Rates ─────────────────────────────────────────────────────
OPEN_EXCHANGE_RATES_APP_ID=your_open_exchange_rates_app_id

# ─── Email (Nodemailer via SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@kodiapp.ke
FROM_NAME=KODI Platform

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32_char_hex_key_for_aes256_encryption

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PATH=./uploads
# Optional: S3 for voice recordings and PDFs
S3_BUCKET=kodi-uploads
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# ─── Airtime Rewards ─────────────────────────────────────────────────────────
DEFAULT_MONTHLY_AIRTIME_CAP_KES=5000   # Per landlord per month
REWARD_3_MONTHS_KES=30
REWARD_6_MONTHS_KES=75
REWARD_12_MONTHS_KES=150

# ─── Rent Advance ────────────────────────────────────────────────────────────
ADVANCE_FEE_PERCENT=3

# ─── Late Fees ───────────────────────────────────────────────────────────────
LATE_FEE_DAILY_PERCENT=0              # Set to e.g. 1 for 1% per day
